[Desktop Entry]
Type=Application
Name=EtherealOS Browser Setup
Comment=Auto-creates Firefox profile on login
Exec=bash -c "mkdir -p ~/.mozilla/firefox/ethereal.default-release && test -f ~/.mozilla/firefox/profiles.ini || echo -e '[Install4F96D1932A9F858E]\nDefault=ethereal.default-release\nLocked=1\n\n[General]\nStartWithLastProfile=1\nVersion=2\n\n[Profile0]\nName=default-release\nIsRelative=1\nPath=ethereal.default-release\nDefault=1' > ~/.mozilla/firefox/profiles.ini"
Icon=firefox
Terminal=false
Hidden=true
X-GNOME-Autostart-enabled=true
