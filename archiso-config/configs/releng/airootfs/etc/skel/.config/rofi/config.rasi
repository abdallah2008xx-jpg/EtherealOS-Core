configuration {
    modi: "drun,run";
    show-icons: true;
    icon-theme: "Papirus";
    terminal: "foot";
    drun-display-format: "{icon} {name}";
    disable-history: false;
    sidebar-mode: false;
    location: 0; /* Center of the screen */
    dpi: 0; /* Auto-detect for High DPI (4k monitors) */
}

@theme "glass"
